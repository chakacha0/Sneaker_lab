# Host Nginx: two applications on the same :80 and :443 (TLS SNI), different server_name.
#
# SneakerLab in Docker publishes on the host (see docker-compose.yml):
#   - frontend: http://127.0.0.1:3002
#   - API:      http://127.0.0.1:8002
#
# Replace:
#   - shop.example.com          → your real domain for this shop (SneakerLab)
#   - other.example.com         → your second app’s domain
#   - 127.0.0.1:8080            → where the second app listens on the host (port + scheme as needed)
#
# Install as e.g. /etc/nginx/sites-available/sneakerlab-multi.conf and symlink into sites-enabled.
# Test: sudo nginx -t && sudo systemctl reload nginx
#
# Certificates: issue with Certbot (see DEPLOY.md). Paths below assume one cert per hostname
# (/etc/letsencrypt/live/<first-domain-in-cert>/). If you use one SAN cert for both names,
# point ssl_certificate to the same files in both HTTPS server blocks.

# ---------------------------------------------------------------------------
# SneakerLab — HTTP → HTTPS
# ---------------------------------------------------------------------------
server {
  listen 80;
  listen [::]:80;
  server_name shop.example.com;

  return 301 https://$host$request_uri;
}

# ---------------------------------------------------------------------------
# SneakerLab — HTTPS (reverse proxy to Docker host ports +2)
# ---------------------------------------------------------------------------
server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name shop.example.com;

  ssl_certificate     /etc/letsencrypt/live/shop.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/shop.example.com/privkey.pem;
  ssl_trusted_certificate /etc/letsencrypt/live/shop.example.com/chain.pem;

  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers off;
  ssl_ciphers "ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384";
  ssl_ecdh_curve X25519:prime256v1:secp384r1;
  ssl_session_cache shared:SSL:10m;
  ssl_session_timeout 1d;
  ssl_session_tickets off;

  ssl_stapling on;
  ssl_stapling_verify on;
  resolver 1.1.1.1 8.8.8.8 valid=300s;
  resolver_timeout 5s;

  add_header X-Frame-Options "SAMEORIGIN" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header Referrer-Policy "strict-origin-when-cross-origin" always;
  add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

  location / {
    proxy_pass http://127.0.0.1:3002;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
  }

  # Same-origin API (optional): point the frontend build at /api and drop hardcoded localhost URLs.
  location /api/ {
    proxy_pass http://127.0.0.1:8002/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
  }
}

# ---------------------------------------------------------------------------
# Second application — HTTP → HTTPS (different server_name, same ports)
# ---------------------------------------------------------------------------
server {
  listen 80;
  listen [::]:80;
  server_name other.example.com;

  return 301 https://$host$request_uri;
}

# ---------------------------------------------------------------------------
# Second application — HTTPS (replace upstream with your app’s host:port)
# ---------------------------------------------------------------------------
server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name other.example.com;

  ssl_certificate     /etc/letsencrypt/live/other.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/other.example.com/privkey.pem;
  ssl_trusted_certificate /etc/letsencrypt/live/other.example.com/chain.pem;

  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers off;
  ssl_ciphers "ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384";
  ssl_ecdh_curve X25519:prime256v1:secp384r1;
  ssl_session_cache shared:SSL:10m;
  ssl_session_timeout 1d;
  ssl_session_tickets off;

  ssl_stapling on;
  ssl_stapling_verify on;
  resolver 1.1.1.1 8.8.8.8 valid=300s;
  resolver_timeout 5s;

  add_header X-Frame-Options "SAMEORIGIN" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header Referrer-Policy "strict-origin-when-cross-origin" always;

  location / {
    proxy_pass http://127.0.0.1:8080;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
  }
}
